{
  "name": "amen-functions",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && PATH=\"/opt/homebrew/opt/openjdk/bin:$PATH\" npx firebase emulators:start --only functions,firestore,auth",
    "test": "PATH=\"/opt/homebrew/opt/openjdk/bin:$PATH\" npx firebase emulators:exec --only firestore 'npx vitest run'",
    "deploy": "npx firebase deploy --only functions,firestore,storage"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^6.6.0"
  },
  "overrides": {
    "@google-cloud/firestore": "^8.6.0",
    "@opentelemetry/core": "^2.9.0",
    "gaxios": "^7.1.6",
    "google-gax": "^5.0.7",
    "retry-request": "^8.0.3",
    "teeny-request": "^10.1.3",
    "ts-deepmerge": "^8.0.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase-functions-test": "^3.5.0",
    "firebase-tools": "^15.22.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
