rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function catalogAdmin() {
      return signedIn()
        && request.auth.token.email == 'j.a.t.creativestudios@gmail.com'
        && request.auth.token.catalogAdmin == true;
    }

    match /prayer_catalog_published/{locale}/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /prayer_catalog_drafts/{scope}/{document=**} {
      allow read, write: if catalogAdmin();
    }

    match /altar_music/{musicId} {
      allow read: if true;
      allow write: if catalogAdmin();
    }

    match /catalog_admin_audit/{auditId} {
      allow read: if catalogAdmin();
      allow write: if false;
    }

    match /intentions/{intentionId} {
      allow read: if resource.data.status == 'approved';
      allow create, update: if false;
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.recipientUid == request.auth.uid;
      allow read: if signedIn() && resource.data.recipientUid == 'community';
      allow create: if false;
      allow update: if signedIn()
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if false;
    }

    match /reports/{reportId} {
      allow read: if false;
      allow create: if false;
      allow update, delete: if false;
    }

    match /device_tokens/{uid}/tokens/{token} {
      allow read: if false;
      allow create, update, delete: if signedIn() && uid == request.auth.uid;
    }

    match /amen_events/{eventId} {
      allow read, write: if false;
    }
  }
}
